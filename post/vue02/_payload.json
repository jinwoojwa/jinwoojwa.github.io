s":129},[95,592,133],{"class":101},[95,594,137],{"class":136},[95,596,140],{"class":105},[95,598,143],{"class":129},[95,600,146],{"class":105},[95,602,603],{"class":97,"line":168},[95,604,120],{"emptyLinePlaceholder":119},[95,606,607],{"class":97,"line":173},[95,608,609],{"class":194},"\u002F\u002F 2. reactive를 유지하며 분해하고 싶을 때 (toRefs 사용)\n",[95,611,612,614,616,618,620,623,625,628,631],{"class":97,"line":185},[95,613,126],{"class":101},[95,615,275],{"class":129},[95,617,133],{"class":101},[95,619,280],{"class":136},[95,621,622],{"class":105},"({ name: ",[95,624,301],{"class":112},[95,626,627],{"class":105},", age: ",[95,629,630],{"class":129},"20",[95,632,510],{"class":105},[95,634,635,637,640,643,646,649,652,654,657,660],{"class":97,"line":198},[95,636,126],{"class":101},[95,638,639],{"class":105}," { ",[95,641,642],{"class":129},"name",[95,644,645],{"class":105},", ",[95,647,648],{"class":129},"age",[95,650,651],{"class":105}," } ",[95,653,530],{"class":101},[95,655,656],{"class":136}," toRefs",[95,658,659],{"class":105},"(state) ",[95,661,662],{"class":194},"\u002F\u002F 각각 ref가 되어 반응성 유지\n",[15,664,665,667],{},[41,666],{},[41,668],{},[10,670,672],{"id":671},"ref-reactive-비유로-이해하기","ref, reactive : 비유로 이해하기",[15,674,675,676,679],{},"Vue의 반응성 시스템을 ",[30,677,678],{},"엑셀(Excel)","에 비유하면 그 차이가 명확해진다.",[41,681],{},[15,683,684,685],{},"1️⃣ ",[19,686,687],{},"ref : 엑셀의 '특정 셀' 하나",[15,689,690,692],{},[30,691,32],{},"는 엑셀 시트 위에서 **이름이 지정된 단 하나의 셀(Cell)**과 같다.",[64,694,695,711],{},[67,696,697,700],{},[19,698,699],{},"값 접근:",[64,701,702,705],{},[67,703,704],{},"A1 셀의 값을 바꾸려면 반드시 해당 셀을 클릭해서 수정해야 한다.",[67,706,707,708,710],{},"이것이 코드에서 ",[30,709,56],{},"를 붙여 데이터에 접근하는 과정과 같다.",[67,712,713,716],{},[19,714,715],{},"독립성:",[64,717,718,721],{},[67,719,720],{},"이 셀을 다른 곳으로 복사하거나 참조하더라도, 엑셀은 여전히 그 셀이 어디를 가리키는지 알고 있다.",[67,722,723],{},"따라서 구조 분해를 하거나 다른 객체에 담아도 반응성(연결고리)이 유지된다.",[41,725],{},[15,727,728,729],{},"2️⃣ ",[19,730,731],{},"reactive: '표(Table) 이름' 그 자체",[15,733,734,736],{},[30,735,36],{},"는 엑셀에서 특정 범위를 '성적표'라는 이름의 표(Table)로 지정한 것과 같다.",[64,738,739,751],{},[67,740,741,743],{},[19,742,699],{},[64,744,745,748],{},[67,746,747],{},"성적표.수학, 성적표.영어처럼 표의 이름(객체)을 통해 내부 셀에 직접 접근하고 수정할 수 있다.",[67,749,750],{},"별도의 .value 같은 래퍼를 거치지 않으며, 표(구조)와 데이터가 하나의 단위처럼 동작한다.",[67,752,753,756],{},[19,754,755],{},"구조 분해의 위험성:",[64,757,758,761],{},[67,759,760],{},"'수학' 점수만 따로 꺼내서 다른 셀에 값으로 붙여넣기를 하면, 그 값은 더 이상 '성적표'와 연결되지 않는다.",[67,762,763],{},"이후 원본 '성적표.수학'을 변경해도, 복사된 값은 변하지 않는 단순한 값이 된다.",[15,765,766,768],{},[41,767],{},[41,769],{},[10,771,772],{"id":772},"정리",[64,774,775,778,786,794,806,818],{},[67,776,777],{},"반응성이란 데이터의 변화를 감지하여 연결된 DOM을 자동으로 업데이트하는 Vue.js의 핵심 시스템이다.",[67,779,780,782,783,785],{},[30,781,32],{},"는 모든 타입의 데이터를 ",[30,784,56],{},"라는 껍데기에 담아 관리하며, 어디서든 참조 주소를 유지하는 독립적인 셀과 같다.",[67,787,788,790,791,793],{},[30,789,36],{},"는 객체 전용 반응성 API로, ",[30,792,56],{}," 없이 속성에 직접 접근할 수 있어 문법적으로 간결하지만 객체 단위로만 동작한다.",[67,795,796,797,799,800,802,803,805],{},"재할당 시 ",[30,798,32],{},"는 ",[30,801,56],{},"를 통해 안전하게 값을 교체할 수 있으나, ",[30,804,36],{},"는 객체 자체를 바꾸면 반응성 연결이 끊어진다.",[67,807,808,809,811,812,814,815,817],{},"구조 분해 할당 시 ",[30,810,36],{},"는 반응성을 잃으므로, 이를 방지하려면 ",[30,813,558],{},"를 사용하거나 처음부터 ",[30,816,32],{},"를 사용하는 것이 권장된다.",[67,819,820,821,823,824,826],{},"비유하자면 ",[30,822,32],{},"는 주소지가 고정된 개별 셀을 클릭하는 방식이고, ",[30,825,36],{},"는 이름 붙은 표 전체를 하나의 영역으로 관리하는 방식이다.",[828,829,830],"style",{},"html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);fo