교체하면 기존 Proxy와의 연결이 끊어진다.",[86,250,252],{"className":88,"code":251,"language":90,"meta":91,"style":91},"import { reactive } from 'vue'\n\nconst state = reactive({\n  count: 0,\n  user: { name: 'kim' }\n})\n\nfunction increment() {\n  state.count++ \u002F\u002F .value가 필요 없음\n}\n",[30,253,254,265,269,284,294,305,310,314,322,333],{"__ignoreMap":91},[95,255,256,258,261,263],{"class":97,"line":98},[95,257,102],{"class":101},[95,259,260],{"class":105}," { reactive } ",[95,262,109],{"class":101},[95,264,113],{"class":112},[95,266,267],{"class":97,"line":116},[95,268,120],{"emptyLinePlaceholder":119},[95,270,271,273,276,278,281],{"class":97,"line":123},[95,272,126],{"class":101},[95,274,275],{"class":129}," state",[95,277,133],{"class":101},[95,279,280],{"class":136}," reactive",[95,282,283],{"class":105},"({\n",[95,285,286,289,291],{"class":97,"line":149},[95,287,288],{"class":105},"  count: ",[95,290,143],{"class":129},[95,292,293],{"class":105},",\n",[95,295,296,299,302],{"class":97,"line":168},[95,297,298],{"class":105},"  user: { name: ",[95,300,301],{"class":112},"'kim'",[95,303,304],{"class":105}," }\n",[95,306,307],{"class":97,"line":173},[95,308,309],{"class":105},"})\n",[95,311,312],{"class":97,"line":185},[95,313,120],{"emptyLinePlaceholder":119},[95,315,316,318,320],{"class":97,"line":198},[95,317,176],{"class":101},[95,319,179],{"class":136},[95,321,182],{"class":105},[95,323,325,328,330],{"class":97,"line":324},9,[95,326,327],{"class":105},"  state.count",[95,329,191],{"class":101},[95,331,332],{"class":194}," \u002F\u002F .value가 필요 없음\n",[95,334,336],{"class":97,"line":335},10,[95,337,201],{"class":105},[15,339,340,342],{},[41,341],{},[41,343],{},[10,345,347],{"id":346},"ref-vs-reactive-무엇을-쓸-것인가","ref vs reactive: 무엇을 쓸 것인가?",[15,349,350,351,353],{},"두 방식 중 무엇을 선택할지는 개발 스타일의 영역이지만, 최근 Vue 생태계에서는 다음과 같은 이유로 ",[30,352,32],{}," 사용을 권장하는 추세이다.",[15,355,356],{},"그 이유는 다음과 같다:",[64,358,359,362,365],{},[67,360,361],{},"reactive는 구조 분해 시 반응성이 깨지기 쉽다.",[67,363,364]