[{"data":1,"prerenderedAt":849},["ShallowReactive",2],{"post-vue02":3},{"id":4,"title":5,"body":6,"date":839,"description":91,"extension":840,"meta":841,"navigation":119,"path":842,"seo":843,"stem":844,"summary":845,"tags":846,"__hash__":848},"content\u002Fposts\u002Fvue02.md","Vue.js 핵심 요약 - 반응성의 기초 (ref, reactive)",{"type":7,"value":8,"toc":831},"minimark",[9,14,23,26,38,45,49,58,63,85,202,208,212,223,227,243,249,338,344,348,354,357,368,370,464,466,469,474,548,560,663,669,673,680,682,688,693,724,726,732,737,764,770,773,827],[10,11,13],"h2",{"id":12},"vuejs의-반응성reactivity이란","Vue.js의 반응성(Reactivity)이란?",[15,16,17,18,22],"p",{},"Vue의 가장 큰 특징 중 하나는 데이터가 변경될 때마다 화면이 자동으로 업데이트되는 ",[19,20,21],"strong",{},"반응성(Reactivity)"," 이다.",[15,24,25],{},"일반적인 JavaScript 객체는 값이 변해도 DOM을 자동으로 갱신하지 않지만, Vue의 반응성 시스템은 데이터의 변화를 감지하여 연결된 템플릿을 다시 렌더링한다.",[15,27,28,29,33,34,37],{},"Composition API에서는 이를 위해 ",[30,31,32],"code",{},"ref","와 ",[30,35,36],{},"reactive","라는 두 가지 핵심 API를 제공한다.",[15,39,40,43],{},[41,42],"br",{},[41,44],{},[10,46,48],{"id":47},"ref-모든-타입에-대응하는-반응성-주입","ref: 모든 타입에 대응하는 반응성 주입",[15,50,51,53,54,57],{},[30,52,32],{},"는 인자로 전달받은 값을 내부의 ",[30,55,56],{},".value"," 속성에 담고 있는 객체로 반환한다. 기본 자료형(String, Number, Boolean)뿐만 아니라 객체나 배열도 다룰 수 있다.",[15,59,60],{},[19,61,62],{},"특징 및 사용법",[64,65,66,76],"ul",{},[67,68,69,72,73,75],"li",{},[19,70,71],{},"값 접근"," : 스크립트 내에서는 항상 ",[30,74,56],{},"를 통해 접근하고 수정해야 한다.",[67,77,78,81,82,84],{},[19,79,80],{},"템플릿 활용"," : template 영역에서는 ",[30,83,56],{},"를 생략하고 변수명 그대로 사용할 수 있다. (자동 언래핑)",[86,87,92],"pre",{"className":88,"code":89,"language":90,"meta":91,"style":91},"language-JavaScript shiki shiki-themes github-dark","import { ref } from 'vue'\n\nconst count = ref(0)\nconst message = ref('Hello World!')\n\nfunction increment() {\n  count.value++ \u002F\u002F 스크립트에서는 .value 필수\n}\n","JavaScript","",[30,93,94,114,121,147,166,171,183,196],{"__ignoreMap":91},[95,96,99,103,107,110],"span",{"class":97,"line":98},"line",1,[95,100,102],{"class":101},"