[{"data":1,"prerenderedAt":877},["ShallowReactive",2],{"post-vue05":3},{"id":4,"title":5,"body":6,"date":867,"description":44,"extension":868,"meta":869,"navigation":85,"path":870,"seo":871,"stem":872,"summary":873,"tags":874,"__hash__":876},"content\u002Fposts\u002Fvue05.md","Vue.js 핵심 요약 - 의존성 주입과 컴포저블",{"type":7,"value":8,"toc":856},"minimark",[9,14,18,26,38,151,154,159,162,165,279,281,285,291,298,327,329,334,351,362,368,372,375,378,395,597,599,603,610,624,728,730,734,737,740,781,783,788,802,809,816,822,826,852],[10,11,13],"h2",{"id":12},"_1-provideinject-프롭-드릴링의-해결","1. Provide\u002FInject: 프롭 드릴링의 해결",[15,16,17],"p",{},"컴포넌트 트리가 깊어지면, 부모에서 아주 깊은 자식 컴포넌트로 데이터를 전달하기 위해 중간 단계의 컴포넌트들이 불필요하게 Props를 전달해야 한다.",[15,19,20,21,25],{},"이를 ",[22,23,24],"strong",{},"'프롭 드릴링(Prop Drilling)'"," 이라 한다.",[15,27,28,29,33,34,37],{},"하지만, ",[30,31,32],"code",{},"provide","와 ",[30,35,36],{},"inject","를 사용하면 중간 단계를 건너뛰고 데이터를 즉시 주입할 수 있다.",[39,40,45],"pre",{"className":41,"code":42,"language":43,"meta":44,"style":44},"language-javascript shiki shiki-themes github-dark","\u002F\u002F 부모 컴포넌트 (데이터 제공)\n\u003Cscript setup>\nimport { provide } from 'vue'\n\nprovide('theme', 'dark')\n\u003C\u002Fscript>\n\n\u002F\u002F 깊은 자식 컴포넌트 (데이터 수신)\n\u003Cscript setup>\nimport { inject } from 'vue'\n\nconst theme = inject('theme')\n\u003C\u002Fscript>\n","javascript","",[30,46,47,56,74,80,87,93,103,108,114,125,131,136,142],{"__ignoreMap":44},[48,49,52],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sAwPA","\u002F\u002F 부모 컴포넌트 (데이터 제공)\n",[48,57,59,63,67,71],{"class":50,"line":58},2,[48,60,62],{"class":61},"s95oV","\u003C",[48,64,66],{"class":65},"s4JwU","script",[48,68,70],{"class":69},"svObZ"," setup",[48,72,73],{"class":61},">\n",[48,75,77],{"class":50,"line":76},3,[48,78,79],{"class":61},"import { provide } from 'vue'\n",[48,81,83],{"class":50,"line":82},4,[48,84,86],{"emptyLinePlaceholder":85},true,"\n",[48,88,90],{"class":50,"line":89},5,[48,91,92],{"class":61},"provide('theme', 'dark')\n",[48,94,96,99,101],{"class":50,"line":95},6,[48,97,98],{"class":61},"\u003C\u002F",[48,100,66],{"class":65},[48,102,73],{"class":61},[48,104,106],{"class":50,"line":105},7,[48,107,86],{"emptyLinePlaceholder":85},[48,109,111],{"class":50,"line":110},8,[48,112,113],{"class":54},"\u002F\u002F 깊은 자식 컴포넌트 (데이터 수신)\n",[48,115,117,119,121,123],{"class":50,"line":116},9,[48,118,62],{"class":61},[48,120,66],{"class":65},[48,122,70],{"class":69},[48,124,73],{"class":61},[48,126,128],{"class":50,"line":127},10,[48,129,130],{"class":61},"import { inject } from 'vue'\n",[48,132,134],{"class":50,"line":133},11,[48,135,86],{"emptyLinePlaceholder":85},[48,137,139],{"class":50,"line":138},12,[48,140,141],{"class":61},"const theme = inject('theme')\n",[48,143,145,147,149],{"class":50,"line":144},13,[48,146,98],{"class":61},[48,148,66],{"class":65},[48,150,73],{"class":61},[152,153],"br",{},[155,156,158],"h3",{"id":157},"tip-안전한-데이터-수정-injection-key","💡 TIP: 안전한 데이터 수정 (Injection Key)",[15,160,161],{},"단순한 값 전달을 넘어, 상태를 수정하는 함수까지 제공하면 부모의 데이터 주도권을 유지하며 자식과 안전하게 소통할 수 있다.",[15,163,164],{},"다시 말하면, 자식은 부모의 상태를 부모가 정한 방식대로만 안전하게 수정할 수 있게 된다.",[39,166,168],{"className":41,"code":167,"language":43,"meta":44,"style":44},"\u002F\u002F 부모: 데이터와 수정 기능을 묶어서 제공\nprovide('userState', {\n  user,\n  updateName: (newName) => {\n    user.name = newName;\n  },\n});\n\n\u002F\u002F 자식: 제공받은 수정 기능만 사용\nconst { user, updateName } = inject('userState');\n",[30,169,170,175,189,194,216,227,232,237,241,246],{"__ignoreMap":44},[48,171,172],{"class":50,"line":51},[48,173,174],{"class":54},"\u002F\u002F 부모: 데이터와 수정 기능을 묶어서 제공\n",[48,176,177,179,182,186],{"class":50,"line":58},[48,178,32],{"class":69},[48,180,181],{"class":61},"(",[48,183,185],{"class":184},"sU2Wk","'userState'",[48,187,188],{"class":61},", {\n",[48,190,191],{"class":50,"line":76},[48,192,193],{"class":61},"  user,\n",[48,195,196,199,202,206,209,213],{"class":50,"line":82},[48,197,198],{"class":69},"  updateName",[48,200,201],{"class":61},": (",[48,203,205],{"class":204},"s9osk","newName",[48,207,208],{"class":61},") ",[48,210,212],{"class":211},"snl16","=>",[48,214,215],{"class":61}," {\n",[48,217,218,221,224],{"class":50,"line":89},[48,219,220],{"class":61},"    user.name ",[48,222,223],{"class":211},"=",[48,225,226],{"class":61}," newName;\n",[48,228,229],{"class":50,"line":95},[48,230,231],{"class":61},"  },\n",[48,233,234],{"class":50,"line":105},[48,235,236],{"class":61},"});\n",[48,238,239],{"class":50,"line":110},[48,240,86],{"emptyLinePlaceholder":85},[48,242,243],{"class":50,"line":116},[48,244,245],{"class":54},"\u002F\u002F 자식: 제공받은 수정 기능만 사용\n",[48,247,248,251,254,258,261,264,267,269,272,274,276],{"class":50,"line":127},[48,249,250],{"class":211},"const",[48,252,253],{"class":61}," { ",[48,255,257],{"class":256},"sDLfK","user",[48,259,260],{"class":61},", ",[48,262,263],{"class":256},"updateName",[48,265,266],{"class":61}," } ",[48,268,223],{"class":211},[48,270,271],{"class":69}," inject",[48,273,181],{"class":61},[48,275,185],{"class":184},[48,277,278],{"class":61},");\n",[152,280],{},[155,282,284],{"id":283},"props-대신-provideinject를-쓰는-게-더-좋은가","💡 Props 대신 Provide\u002FInject를 쓰는 게 더 좋은가?",[15,286,287,288],{},"결론부터 말하자면 ",[22,289,290],{},"아니다.",[15,292,293,294,297],{},"대부분의 경우 ",[22,295,296],{},"Props를 사용하는 것이 정석이다."," 그 이유는 다음과 같다.",[299,300,301,316],"ul",{},[302,303,304,307,308,311,312,315],"li",{},[22,305,306],{},"데이터의 흐름 추적 (Props의 장점):"," ",[30,309,310],{},"Props","는 코드를 보면 어느 부모 컴포넌트가 이 데이터를 자식에게 전달했는지 한눈에 알 수 있다. 반면, ",[30,313,314],{},"provide\u002Finject","는 데이터가 어디서 제공되었는지 직관적으로 찾기 어려워, 규모가 큰 애플리케이션에서는 데이터의 흐름을 쫓기가 힘들 수 있다.",[302,317,318,307,321,323,324,326],{},[22,319,320],{},"재사용성 (Props의 장점):",[30,322,310],{},"를 받는 컴포넌트는 \"데이터만 넣어주면 어디서든 작동하는\" 독립적인 부품이 된다. 하지만 ",[30,325,36],{},"를 사용하는 컴포넌트는 특정 부모가 데이터를 제공해주지 않으면 작동하지 않는 '의존적인 부품'이 된다.",[152,328],{},[15,330,331],{},[22,332,333],{},"❓ 언제 무엇을 써야 하는가?",[299,335,336,341],{},[302,337,338,340],{},[30,339,310],{},": 대부분의 일반적인 부모-자식 관계 (90% 이상)",[302,342,343,346,347,350],{},[30,344,345],{},"Provide\u002FInject",": 아주 깊게 중첩된 컴포넌트 구조에서 테마(색상), 사용자 정보, 다국어 설정처럼 ",[22,348,349],{},"앱 전체에서 공통으로 공유해야 하는 '전역적인 데이터'"," 를 전달할 때",[15,352,353,354,357,358,361],{},"요약하자면, 컴포넌트끼리 직접적인 부모-자식 관계를 맺고 있다면, ",[22,355,356],{},"Props를 우선적으로 사용 하고,"," 여러 곳에서 공통으로 참조해야 하는 배경 데이터라면 ",[22,359,360],{},"Provide\u002FInject를 사용"," 하는 것이 건강한 설계이다.",[15,363,364,366],{},[152,365],{},[152,367],{},[10,369,371],{"id":370},"_2-컴포저블composables-로직-재사용","2. 컴포저블(Composables): 로직 재사용",[15,373,374],{},"Composition API의 가장 강력한 장점이다.",[15,376,377],{},"특정 기능을 수행하는 로직을 별도의 함수로 분리하여 여러 컴포넌트에서 재사용할 수 있다.",[299,379,380,389],{},[302,381,382,307,385,388],{},[22,383,384],{},"규칙:",[30,386,387],{},"use","로 시작하는 함수명을 사용한다 (예: useMouse, useFetch).",[302,390,391,394],{},[22,392,393],{},"장점:"," 컴포넌트 내부가 비즈니스 로직으로 복잡해지는 것을 막고, 로직을 독립적으로 테스트할 수 있다.",[39,396,398],{"className":41,"code":397,"language":43,"meta":44,"style":44},"\u002F\u002F useMouse.js (재사용 가능한 로직)\nimport { ref, onMounted, onUnmounted } from 'vue';\n\nexport function useMouse() {\n  const x = ref(0);\n  const y = ref(0);\n\n  const update = (e) => {\n    x.value = e.pageX;\n    y.value = e.pageY;\n  };\n\n  onMounted(() => window.addEventListener('mousemove', update));\n  onUnmounted(() => window.removeEventListener('mousemove', update));\n\n  return { x, y };\n}\n",[30,399,400,405,422,426,440,461,478,482,503,513,523,528,532,556,577,582,591],{"__ignoreMap":44},[48,401,402],{"class":50,"line":51},[48,403,404],{"class":54},"\u002F\u002F useMouse.js (재사용 가능한 로직)\n",[48,406,407,410,413,416,419],{"class":50,"line":58},[48,408,409],{"class":211},"import",[48,411,412],{"class":61}," { ref, onMounted, onUnmounted } ",[48,414,415],{"class":211},"from",[48,417,418],{"class":184}," 'vue'",[48,420,421],{"class":61},";\n",[48,423,424],{"class":50,"line":76},[48,425,86],{"emptyLinePlaceholder":85},[48,427,428,431,434,437],{"class":50,"line":82},[48,429,430],{"class":211},"export",[48,432,433