},[48,569,570],{"class":69},"removeEventListener",[48,572,181],{"class":61},[48,574,552],{"class":184},[48,576,555],{"class":61},[48,578,580],{"class":50,"line":579},15,[48,581,86],{"emptyLinePlaceholder":85},[48,583,585,588],{"class":50,"line":584},16,[48,586,587],{"class":211},"  return",[48,589,590],{"class":61}," { x, y };\n",[48,592,594],{"class":50,"line":593},17,[48,595,596],{"class":61},"}\n",[152,598],{},[155,600,602],{"id":601},"tip-composable은-상태를-어떻게-공유하는가","💡 TIP: Composable은 상태를 어떻게 공유하는가?",[15,604,605,606,609],{},"컴포저블을 사용할 때 ",[22,607,608],{},"\"상태를 어디에 선언하느냐\""," 에 따라 데이터가 공유될지, 독립적일지 결정된다.",[299,611,612,618],{},[302,613,614,617],{},[22,615,616],{},"독립적 상태 (함수 내부 선언):"," 함수를 부를 때마다 새로운 공간이 생긴다. 컴포넌트마다 각자의 카운터를 가진다.",[302,619,620,623],{},[22,621,622],{},"공유 상태 (함수 외부 선언):"," 함수 바깥에 변수를 두면, 앱 전체에서 하나의 변수를 같이 쓴다. 앱 어디서든 똑같은 값을 공유한다.",[39,625,627],{"className":41,"code":626,"language":43,"meta":44,"style":44},"\u002F\u002F 독립적 상태 (함수 내부 선언 시)\nexport function useCounter() {\n  const count = ref(0); \u002F\u002F 호출될 때마다 새로운 count 생성\n  return { count };\n}\n\n\u002F\u002F 공유 상태 (함수 외부 선언 시)\nconst sharedCount = ref(0);\nexport function useSharedCounter() {\n  return { count: sharedCount }; \u002F\u002F 모든 호출자가 같은 값을 공유\n}\n",[30,628,629,634,645,666,673,677,681,686,703,714,724],{"__ignoreMap":44},[48,630,631],{"class":50,"line":51},[48,632,633],{"class":54},"\u002F\u002F 독립적 상태 (함수 내부 선언 시)\n",[48,635,636,638,640,643],{"class":50,"line":58},[48,637,430],{"class":211},[48,639,433],{"class":211},[48,641,642],{"class":69}," useCounter",[48,644,439],{"class":61},[48,646,647,649,652,654,656,658,660,663],{"class":50,"line":76},[48,648,444],{"class":211},[48,650,651],{"class":256}," count",[48,653,450],{"class":211},[48,655,453],{"class":69},[48,657,181],{"class":61},[48,659,458],{"class":256},[48,661,662],{"class":61},"); ",[48,664,665],{"class":54},"\u002F\u002F 호출될 때마다 새로운 count 생성\n",[48,667,668,670],{"class":50,"line":82},[48,669,587],{"class":211},[48,671,672],{"class":61}," { count };\n",[48,674,675],{"class":50,"line":89},[48,676,596],{"class":61},[48,678,679],{"class":50,"line":95},[48,680,86],{"emptyLinePlaceholder":85},[48,682,683],{"class":50,"line":105},[48,684,685],{"class":54},"\u002F\u002F 공유 상태 (함수 외부 선언 시)\n",[48,687,688,690,693,695,697,699,701],{"class":50,"line":110},[48,689,250],{"class":211},[48,691,692],{"class":256}," sharedCount",[48,694,450],{"class":211},[48,696,453],{"class":69},[48,698,181],{"class":61},[48,700,458],{"class":256},[48,702,278],{"class":61},[48,704,705,707,709,712],{"class":50,"line":116},[48,706,430],{"class":211},[48,708,433],{"class":211},[48,710,711],{"class":69}," useSharedCounter",[48,713,439],{"class":61},[48,715,716,718,721],{"class":50,"line":127},[48,717,587],{"class":211},[48,719,720],{"class":61}," { count: sharedCount }; ",[48,722,723],{"class":54},"\u002F\u002F 모든 호출자가 같은 값을 공유\n",[48,725,726],{"class":50,"line":133},[48,727,596],{"class":61},[152,729],{},[155,731,733],{"id":732},"컴포저블composable-무조건-분리하는-것이-좋은가","💡 컴포저블(Composable), 무조건 분리하는 것이 좋은가?",[15,735,736],{},"컴포저블은 '로직의 모듈화' 를 돕지만, 모든 로직을 쪼개서 사용하는 것이 능사는 아니다.",[15,738,739],{},"다음 기준을 참고하여 분리 여부를 결정하는 것이 좋다.",[299,741,742,755,768],{},[302,743,744,747],{},[22,745,746],{},"로직의 재사용성:",[299,748,749,752],{},[302,750,751],{},"동일한 로직이 두 개 이상의 컴포넌트에서 반복되는가? 그렇다면 컴포저블로 분리하는 것이 좋다.",[302,753,754],{},"만약 특정 컴포넌트에서만 사용되는 로직이라면, 굳이 외부 파일로 분리하지 않고 컴포넌트 내부에 두는 것이 오히려 좋을 수 있다.",[302,756,757,760],{},[22,758,759],{},"컴포넌트의 단순화:",[299,761,762,765],{},[302,763,764],{},"스크립트 코드가 너무 길어져서 '무슨 일을 하는지' 한눈에 파악하기 어렵다면, 컴포저블로 분리하는 것이 좋다.",[302,766,767],{},"로직이 비즈니스 로직(데이터 처리, API 호출)과 UI 로직(DOM 이벤트, 템플릿 제어)으로 섞여 있다면, 비즈니스 로직을 컴포저블로 분리하여 컴포넌트를 단순화 하는 것이 좋다.",[302,769,770,773],{},[22,771,772],{},"테스트 가능성:",[299,774,775,778],{},[302,776,777],{},"특정 로직을 컴포넌트와 분리해서 단독으로 테스트하고 싶은가?",[302,779,780],{},"컴포저블로 만들면 순수 함수처럼 테스트하기 훨씬 수월해진다.",[152,782],{},[15,784,785],{},[22,786,787],{},"❓ 언제 무엇을 선택할까?",[299,789,790,796],{},[302,791,792,795],{},[22,793,794],{},"컴포넌트 내부에 유지:"," 특정 컴포넌트에서만 쓰이는 간단한 로직",[302,797,798,801],{},[22,799,800],{},"컴포저블로 분리:"," 여러 컴포넌트에서 공통으로 호출하는 기능, 컴포넌트의 가독성을 해칠 정도로 방대한 로직",[15,803,804,805,808],{},"요약하면, 컴포저블은 ",[22,806,807],{},"재사용성과 관심사 분리"," 를 위한 도구이다.",[15,810,811,812,815],{},"단순히 코드를 쪼개는 것에 매몰되지 말고, ",[22,813,814],{},"이 로직이 다른 곳에서도 쓰일 가능성이 있는가?"," 를 먼저 고민하는 것이 좋다.",[15,817,818,820],{},[152,819],{},[152,821],{},[10,823,825],{"id":824},"정리","📚 정리",[299,827,828,833,839],{},[302,829,830,832],{},[22,831,345],{}," 는 복잡한 부모-자식 연결망을 건너뛰어 데이터를 직접 전달하는 '데이터 전용 통신망' 이다.",[302,834,835,838],{},[22,836,837],{},"컴포저블"," 은 반복되는 로직을 '레고 블록' 처럼 독립적인 함수로 만들어 코드 재사용성을 높이는 패턴이다.",[302,840,841,844,845,847,848,851],{},[22,842,843],{},"핵심:"," 애플리케이션의 규모가 커질수록 컴포저블을 활용해 로직을 잘게 쪼개고, 전역적인 데이터는 ",[30,846,345],{},"나 ",[30,849,850],{},"Pinia","를 통해 효율적으로 관리해야 한다.",[853,854,855],"style",{},"html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .s4JwU, html code.shiki .s4JwU{--shiki-default:#85E89D}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .s9osk, html code.shiki .s9osk{--shiki-default:#FFAB70}html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}",{"title":44,"searchDepth":58,"depth":58,"links":857},[858,862,866],{"id":12,"d