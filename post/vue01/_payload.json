94,795,797],"h3",{"id":796},"애플리케이션-인스턴스","애플리케이션 인스턴스",[15,799,800],{},"모든 Vue 애플리케이션은 createApp 함수를 사용하여 새로운 애플리케이션 인스턴스를 생성하는 것에서 시작한다.",[15,802,803],{},"이 인스턴스는 앱 전체에 적용될 설정이나 에셋을 등록하는 중심축 역할을 한다.",[38,805,807],{"className":40,"code":806,"language":42,"meta":43,"style":43},"import { createApp } from 'vue';\nconst app = createApp({});\n",[18,808,809,822],{"__ignoreMap":43},[47,810,811,813,816,818,820],{"class":49,"line":50},[47,812,54],{"class":53},[47,814,815],{"class":57}," { createApp } ",[47,817,61],{"class":53},[47,819,65],{"class":64},[47,821,209],{"class":57},[47,823,824,826,829,831,834],{"class":49,"line":71},[47,825,214],{"class":53},[47,827,828],{"class":217}," app",[47,830,221],{"class":53},[47,832,833],{"class":100}," createApp",[47,835,836],{"class":57},"({});\n",[158,838],{},[794,840,842],{"id":841},"루트-컴포넌트","루트 컴포넌트",[15,844,845,848],{},[18,846,847],{},"createApp","에 전달되는 객체는 사실상 컴포넌트다.",[15,850,851,852,855,856,859],{},"모든 앱은 다른 컴포넌트들을 자식으로 포함할 수 있는 ",[26,853,854],{},"루트(Root) 컴포넌트","가 필요하며, 일반적으로 ",[18,857,858],{},"App.vue"," 파일이 그 역할을 수행한다.",[38,861,863],{"className":40,"code":862,"language":42,"meta":43,"style":43},"import { createApp } from 'vue'; \u002F\u002F SFC에서 루트 컴포넌트 App을 import import\nApp from '.\u002FApp.vue'; const app = createApp(App);\n",[18,864,865,881],{"__ignoreMap":43},[47,866,867,869,871,873,875,878],{"class":49,"line":50},[47,868,54],{"class":53},[47,870,815],{"class":57},[47,872,61],{"class":53},[47,874,65],{"class":64},[47,876,877],{"class":57},"; ",[47,879,880],{"class":387},"\u002F\u002F SFC에서 루트 컴포넌트 App을 import import\n",[47,882,883,886,889,891,893,895,897,899],{"class":49,"line":71},[47,884,885],{"class":57},"App from ",[47,887,888],{"class":64},"'.\u002FApp.vue'",[47,890,877],{"class":57},[47,892,214],{"class":53},[47,894,828],{"class":217},[47,896,221],{"class":53},[47,898,833],{"class":100},[47,900,901],{"class":57},"(App);\n",[158,903],{},[794,905,907],{"id":906},"애플리케이션-마운트","애플리케이션 마운트",[15,909,910,911,914],{},"애플리케이션 인스턴스는 ",[18,912,913],{},".mount()"," 메서드가 호출되기 전까지는 아무것도 렌더링하지 않는다.",[15,916,917],{},"이 메서드는 실제 HTML 요소(컨테이너)의 셀렉터나 DOM 객체를 인자로 받는다.",[15,919,920],{},"주의할 점은 앱의 모든 설정(에러 핸들러, 컴포넌트 등록 등)은 반드시 마운트하기 전에 완료되어야 한다는 것이다.",[158,922],{},[794,924,926],{"id":925},"앱-설정","앱 설정",[15,928,929,930,933],{},"인스턴스의 ",[18,931,932],{},".config"," 객체를 활용하면 애플리케이션 수준의 에러를 처리하거나 전역 속성을 정의할 수 있다.",[15,935,936,937,940],{},"또한, ",[18,938,939],{},".component()"," 메서드를 사용하여 특정 컴포넌트를 전역으로 등록하면 앱 내 어느 곳에서든 별도의 import 없이 해당 컴포넌트를 사용할 수 있다.",[38,942,944],{"className":40,"code":943,"language":42,"meta":43,"style":43},"app.config.errorHandler = (err) => { \u002F\u002F 오류 처리 }; app.component('HelloBtn',\nHelloBtn);\n",[18,945,946,974],{"__ignoreMap":43},[47,947,948,951,954,956,959,963,966,968,971],{"class":49,"line":50},[47,949,950],{"class":57},"app.config.",[47,952,953],{"class":100},"errorHandler",[47,955,221],{"class":53},[47,957,958],{"class":57}," (",[47,960,962],{"class":961},"s9osk","err",[47,964,965],{"class":57},") ",[47,967,677],{"class":53},[47,969,970],{"class":57}," { ",[47,972,973],{"class":387},"\u002F\u002F 오류 처리 }; app.component('HelloBtn',\n",[47,975,976],{"class":49,"line":71},[47,977,978],{"class":57},"HelloBtn);\n",[15,980,981,983],{},[158,982],{},[158,984],{},[10,986,987],{"id":987},"정리",[140,989,990,997,1003],{},[143,991,992,993,996],{},"Vue는 ",[18,994,995],{},"싱글 파일 컴포넌트(SFC) 구조","를 사용하여 HTML, CSS, JS를 하나의 파일에서 체계적으로 관리하고 캡슐화한다.",[143,998,999,1000,1002],{},"모든 앱은 하나의 루트 컴포넌트에서 시작하여 트리 구조로 확장되며, ",[18,1001,847],{},"을 통해 생성된 인스턴스가 그 중심 역할을 한다.",[143,1004,1005,1006,1008],{},"생성된 인스턴스는 반드시 특정 HTML 요소에 ",[18,1007,913],{}," 되어야만 실제 화면에 렌더링되며, 마운트 전 모든 전역 설정이 완료되어야 한다.",[299,1010,1011],{},"html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .s4JwU, html code.shiki .s4JwU{--shiki-default