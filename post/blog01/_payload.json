[{"data":1,"prerenderedAt":1292},["ShallowReactive",2],{"post-blog01":3},{"id":4,"title":5,"body":6,"date":1282,"description":96,"extension":1283,"meta":1284,"navigation":345,"path":1285,"seo":1286,"stem":1287,"summary":1288,"tags":1289,"__hash__":1291},"content\u002Fposts\u002Fblog01.md","Vue + Vite로 블로그 만들기 (1) - GitHub Pages 배포까지",{"type":7,"value":8,"toc":1273},"minimark",[9,14,23,26,29,35,38,41,57,67,73,77,84,87,90,116,119,136,139,141,144,156,159,174,177,185,188,191,197,201,210,213,220,223,237,240,242,245,260,267,270,278,281,284,469,471,478,488,515,517,523,526,529,535,544,547,554,557,566,572,581,583,589,598,601,607,611,614,617,628,631,637,640,642,648,654,657,663,674,677,680,682,688,694,697,699,710,713,716,718,724,730,733,736,750,753,755,761,767,770,773,779,790,793,795,821,824,830,834,837,843,846,849,865,872,877,884,890,894,901,904,915,918,923,1211,1214,1235,1238,1240,1243,1249,1251,1254,1257,1260,1263,1266,1269],[10,11,13],"h2",{"id":12},"vue-vite로-개발-블로그-만들기-1","Vue + Vite로 개발 블로그 만들기 (1)",[15,16,17,18,22],"p",{},"원래는 ",[19,20,21],"strong",{},"Jekyll + GitHub Pages"," 기반으로 블로그를 운영하고 있었다.\nGitHub Pages와 잘 맞고 정적 블로그를 빠르게 만들 수 있다는 장점이 있어서 사용하게 되었다.",[15,24,25],{},"하지만 Jekyll은 Ruby 기반이다 보니 종종 불편한 점이 있었다.\nRuby와 Jekyll의 버전을 맞춰야 하거나, gem 충돌이 발생하는 경우가 있었고\n환경 설정을 다시 맞추는 데 시간을 쓰는 일이 생기곤 했다.",[15,27,28],{},"최근에 Vue를 공부하게 되면서,\n이왕이면 블로그도 직접 만들어보면 좋겠다는 생각이 들었다.",[15,30,31,32],{},"그래서 이번 기회에 ",[19,33,34],{},"Vue + Vite 기반으로 직접 정적 블로그를 만들어보기로 했다.",[36,37],"br",{},[15,39,40],{},"이번 글에서는 아래 과정까지 진행했다.",[42,43,44,48,51,54],"ul",{},[45,46,47],"li",{},"Vue + Vite 프로젝트 생성",[45,49,50],{},"Vue Router 설정",[45,52,53],{},"Markdown 기반 블로그 구조 설계",[45,55,56],{},"Github Pages 배포",[58,59,60],"blockquote",{},[15,61,62,63,66],{},"모든 과정은 ",[19,64,65],{},"Mac 환경","에서 진행했습니다.",[15,68,69,71],{},[36,70],{},[36,72],{},[10,74,76],{"id":75},"_1-프로젝트-생성","1. 프로젝트 생성",[15,78,79,80,83],{},"먼저 ",[19,81,82],{},"Vite","를 이용해 Vue 프로젝트를 생성했다.",[15,85,86],{},"Vite는 빠른 개발 서버와 간단한 설정을 제공하는 프론트엔드 빌드 도구로 최근 Vue 프로젝트에서 많이 사용되는 방식이다.",[15,88,89],{},"다음 명령어를 실행하면 프로젝트를 생성할 수 있다.",[91,92,97],"pre",{"className":93,"code":94,"language":95,"meta":96,"style":96},"language-bash shiki shiki-themes github-dark","npm create vite@latest\n","bash","",[98,99,100],"code",{"__ignoreMap":96},[101,102,105,109,113],"span",{"class":103,"line":104},"line",1,[101,106,108],{"class":107},"svObZ","npm",[101,110,112],{"class":111},"sU2Wk"," create",[101,114,115],{"class":111}," vite@latest\n",[15,117,118],{},"명령어를 실행하면 몇 가지 선택 옵션이 나오는데",[42,120,121,124,130],{},[45,122,123],{},"프로젝트 이름 입력",[45,125,126,127],{},"Framework 선택 → ",[19,128,129],{},"Vue",[45,131,132,133],{},"Variant 선택 → ",[19,134,135],{},"JavaScript",[15,137,138],{},"위 순서로 진행했다.",[36,140],{},[15,142,143],{},"프로젝트 생성 후 의존성을 설치한다.",[91,145,147],{"className":93,"code":146,"language":95,"meta":96,"style":96},"npm install\n",[98,148,149],{"__ignoreMap":96},[101,150,151,153],{"class":103,"line":104},[101,152,108],{"class":107},[101,154,155],{"class":111}," install\n",[15,157,158],{},"설치가 완료되면 다음 명령어를 통해 로컬 서버를 실행할 수 있다.",[91,160,162],{"className":93,"code":161,"language":95,"meta":96,"style":96},"npm run dev\n",[98,163,164],{"__ignoreMap":96},[101,165,166,168,171],{"class":103,"line":104},[101,167,108],{"class":107},[101,169,170],{"class":111}," run",[101,172,173],{"class":111}," dev\n",[15,175,176],{},"기본적으로 아래 주소를 통해 기본 페이지를 확인할 수 있다.",[91,178,183],{"className":179,"code":181,"language":182},[180],"language-text","http:\u002F\u002Flocalhost:5173\n","text",[98,184,181],{"__ignoreMap":96},[15,186,187],{},"Vite의 장점 중 하나는 개발 서버가 매우 빠르게 실행된다는 점이다.",[15,189,190],{},"또한 파일을 수정하면 즉시 화면에 반영되는 HMR(Hot Module Replacement) 기능도 제공한다.",[15,192,193,195],{},[36,194],{},[36,196],{},[10,198,200],{"id":199},"_2-vue-router-설치","2. Vue Router 설치",[58,202,203],{},[15,204,205,206,209],{},"Vue는 기본적으로 ",[19,207,208],{},"SPA(Single Page Application)"," 구조로 동작한다.",[15,211,212],{},"SPA에서는 페이지를 이동할 때 서버에서 새로운 HTML을 받아오는 것이 아니라\n하나의 페이지 안에서 화면만 변경하는 방식으로 동작한다.",[15,214,215,216,219],{},"이때 URL에 따라 어떤 컴포넌트를 보여줄지 관리하는 라이브러리가 바로 ",[19,217,218],{},"Vue Router"," 이다.",[15,221,222],{},"예를 들어",[42,224,225,231],{},[45,226,227,230],{},[98,228,229],{},"\u002F"," → 홈 화면",[45,232,233,236],{},[98,234,235],{},"\u002Fpost\u002Fslug"," → 특정 블로그 글",[15,238,239],{},"과 같이 URL에 따라 다른 화면을 보여줄 수 있다.",[36,241],{},[15,243,244],{},"먼저 Vue Router를 설치한다.",[91,246,248],{"className":93,"code":247,"language":95,"meta":96,"style":96},"npm install vue-router\n",[98,249,250],{"__ignoreMap":96},[101,251,252,254,257],{"class":103,"line":104},[101,253,108],{"class":107},[101,255,256],{"class":111}," install",[101,258,259],{"class":111}," vue-router\n",[15,261,262,263,266],{},"이후 프로젝트에 ",[98,264,265],{},"src\u002Frouter\u002Findex.js"," 파일을 생성하고 다음과 같이 라우터를 설정했다.",[15,268,269],{},"현재는",[42,271,272,275],{},[45,273,274],{},"홈 페이지",[45,276,277],{},"블로그 글 상세 페이지",[15,279,280],{},"두 개의 라우트만 간단하게 구성했다.",[15,282,283],{},"블로그 기능이 늘어나면 라우팅 구조도 조금 더 확장할 예정이다.",[91,285,289],{"className":286,"code":287,"language":288,"meta":96,"style":96},"language-js shiki shiki-themes github-dark","import { createRouter, createWebHashHistory } from 'vue-router';\nimport Home from '..\u002Fpages\u002FHome.vue';\nimport PostDetail from '..\u002Fpages\u002FPostDetail.vue';\n\nconst router = createRouter({\n  history: createWebHashHistory(),\n  routes: [\n    {\n      path: '\u002F',\n      component: Home,\n    },\n    {\n      path: '\u002Fpost\u002F:slug',\n      component: PostDetail,\n    },\n  ],\n});\n\nexport default router;\n","js",[98,290,291,310,325,340,347,366,378,384,390,402,408,414,419,429,435,440,446,452,457],{"__ignoreMap":96},[101,292,293,297,301,304,307],{"class":103,"line":104},[101,294,296],{"class":295},"snl16","import",[101,298,300],{"class":299},"s95oV"," { createRouter, createWebHashHistory } ",[101,302,303],{"class":295},"from",[101,305,306],{"class":111}," 'vue-router'",[101,308,309],{"class":299},";\n",[101,311,313,315,318,320,323],{"class":103,"line":312},2,[101,314,296],