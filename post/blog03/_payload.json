ile = typeof window !== 'undefined' && window.innerWidth \u003C 768;\n  const widthParam = isMobile ? 'w_500' : 'w_800';\n\n  \u002F\u002F 2. 최적화 파라미터 조합 (포맷\u002F품질 자동화 + 너비 조절)\n  const optimizationParams = `f_auto,q_auto,${widthParam}\u002F`;\n\n  \u002F\u002F 3. 정규표현식으로 원본 URL을 최적화 URL로 일괄 치환\n  return content.replace(\n    new RegExp(BASE_URL, 'g'),\n    BASE_URL + optimizationParams,\n  );\n};\n","javascript","",[68,94,95,104,138,144,184,211,218,224,245,250,256,271,295,307,313],{"__ignoreMap":92},[96,97,100],"span",{"class":98,"line":99},"line",1,[96,101,103],{"class":102},"sAwPA","\u002F\u002F utils\u002Fcloudinary.js 핵심 로직\n",[96,105,107,111,114,118,121,125,129,132,135],{"class":98,"line":106},2,[96,108,110],{"class":109},"snl16","export",[96,112,113],{"class":109}," const",[96,115,117],{"class":116},"svObZ"," optimizeCloudinaryImages",[96,119,120],{"class":109}," =",[96,122,124],{"class":123},"s95oV"," (",[96,126,128],{"class":127},"s9osk","content",[96,130,131],{"class":123},") ",[96,133,134],{"class":109},"=>",[96,136,137],{"class":123}," {\n",[96,139,141],{"class":98,"line":140},3,[96,142,143],{"class":102},"  \u002F\u002F 1. 접속 기기에 따른 동적 너비 설정 (모바일: 500px, 데스크탑: 800px)\n",[96,145,147,150,154,156,159,162,165,169,172,175,178,181],{"class":98,"line":146},4,[96,148,149],{"class":109},"  const",[96,151,153],{"class":152},"sDLfK"," isMobile",[96,155,120],{"class":109},[96,157,158],{"class":109}," typeof",[96,160,161],{"class":123}," window ",[96,163,164],{"class":109},"!==",[96,166,168],{"class":167},"sU2Wk"," 'undefined'",[96,170,171],{"class":109}," &&",[96,173,174],{"class":123}," window.innerWidth ",[96,176,177],{"class":109},"\u003C",[96,179,180],{"class":152}," 768",[96,182,183],{"class":123},";\n",[96,185,187,189,192,194,197,200,203,206,209],{"class":98,"line":186},5,[96,188,149],{"class":109},[96,190,191],{"class":152}," widthParam",[96,193,120],{"class":109},[96,195,196],{"class":123}," isMobile ",[96,198,199],{"class":109},"?",[96,201,202],{"class":