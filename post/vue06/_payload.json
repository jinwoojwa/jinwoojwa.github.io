],{},"props","와 ",[39,578,579],{},"emit","만으로는 데이터 전달이 복잡해진다. ",[39,582,583],{},"Pinia","는 앱 어디서든 접근할 수 있는 '공용 저장소' 를 제공한다.",[15,586,587],{},[25,588,589],{},"핵심 구성:",[19,591,592,598,604],{},[22,593,594,597],{},[39,595,596],{},"state",": 저장소의 데이터(반응형 변수).",[22,599,600,603],{},[39,601,602],{},"getters",": 상태를 계산된 값으로 반환(computed와 동일).",[22,605,606,609],{},[39,607,608],{},"actions",": 상태 변경과 비즈니스 로직을 담당하는 함수. 비동기 처리가 가능하며, 컴포넌트의 methods와 역할이 유사",[64,611,613],{"className":66,"code":612,"language":68,"meta":69,"style":69},"\u002F\u002F useCounterStore.js\nimport { ref, computed } from 'vue';\nimport { defineStore } from 'pinia';\n\nexport const useCounterStore = defineStore('counter', () => {\n  const count = ref(0);\n  const doubleCount = computed(() => count.value * 2);\n  function increment() {\n    count.value++;\n  }\n\n  return { count, doubleCount, increment };\n});\n",[39,614,615,620,633,647,651,680,700,728,739,749,754,758,766],{"__ignoreMap":69},[73,616,617],{"class":75,"line":76},[73,618,619],{"class":79},"\u002F\u002F useCounterStore.js\n",[73,621,622,624,627,629,631],{"class":75,"line":83},[73,623,87],{"class":86},[73,625,626],{"class":90}," { ref, computed } ",[73,628,94],{"class":86},[73,630,280],{"class":97},[73,632,101],{"class":90},[73,634,635,637,640,642,645],{"class":75,"line":104},[73,636,87],{"class":86},[73,638,639],{"class":90}," { defineStore } ",[73,641,94],{"class":86},[73,643,644],{"class":97}," 'pinia'",[73,646,101],{"class":90},[73,648,649],{"class":75,"line":119},[73,650,138],{"emptyLinePlaceholder":137},[73,652,653,655,658,661,663,666,668,671,674,677],{"class":75,"line":134},[73,654,235],{"class":86},[73,656,657],{"class":86}," const",[73,659,660],{"class":147}," useCounterStore",[73,662,151],{"class":86},[73,664,665],{"class":201}," defineStore",[73,667,361],{"class":90},[73,669,670],{"class":97},"'counter'",[73,672,673],{"class":90},", () ",[73,675,676],{"class":86},"=>",[73,678,679],{"class":90}," {\n",[73,681,682,685,688,690,693,695,698