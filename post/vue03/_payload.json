[{"data":1,"prerenderedAt":560},["ShallowReactive",2],{"post-vue03":3},{"id":4,"title":5,"body":6,"date":550,"description":100,"extension":551,"meta":552,"navigation":128,"path":553,"seo":554,"stem":555,"summary":556,"tags":557,"__hash__":559},"content\u002Fposts\u002Fvue03.md","Vue.js 핵심 요약 - 데이터 가공과 감시 (computed, watch)",{"type":7,"value":8,"toc":542},"minimark",[9,14,31,41,48,52,57,67,72,94,213,219,223,228,240,244,267,369,375,379,453,455,460,477,483,487,508,514,517,538],[10,11,13],"h2",{"id":12},"데이터의-변화를-다루는-두-가지-방법","데이터의 변화를 다루는 두 가지 방법",[15,16,17,21,22,25,26,30],"p",{},[18,19,20],"code",{},"ref","와 ",[18,23,24],{},"reactive","로 반응형 데이터를 선언하여 값을 저장할 수 있으며, 이를 통해 화면을 값에 따라 업데이트 할 수 있다. 하지만 실제 애플리케이션에서는 단순히 값을 저장하는 것 이상으로, ",[27,28,29],"strong",{},"데이터가 변할 때 특정 계산을 수행하거나 사이드 이펙트(API 호출 등)를 실행","해야 하는 경우가 많다.",[15,32,33,34,21,37,40],{},"이때 사용하는 핵심 도구가 바로 ",[18,35,36],{},"computed",[18,38,39],{},"watch","이다.",[15,42,43,46],{},[44,45],"br",{},[44,47],{},[10,49,51],{"id":50},"computed-계산된-속성","computed: 계산된 속성",[15,53,54,56],{},[18,55,36],{},"는 기존 데이터를 기반으로 새로운 값을 생성할 때 사용한다.",[15,58,59,60,63,64,66],{},"핵심은 ",[27,61,62],{},"'캐싱(Caching)'"," 이다. 의존하는 데이터가 변경되지 않는 한, ",[18,65,36],{},"는 이전 계산 결과를 재사용한다.",[15,68,69],{},[27,70,71],{},"특징 및 사용법",[73,74,75,82,88],"ul",{},[76,77,78,81],"li",{},[27,79,80],{},"자동 캐싱:"," 의존성(내부 데이터)이 변하지 않으면 다시 계산하지 않고 이전 값을 즉시 반환한다.",[76,83,84,87],{},[27,85,86],{},"성능 최적화:"," 무거운 로직을 반복적으로 수행할 필요가 없을 때 매우 효율적이다.",[76,89,90,93],{},[27,91,92],{},"읽기 전용:"," 기본적으로는 값을 읽기만 하는 것이 원칙이다. (필요 시 getter\u002Fsetter 구현 가능)",[95,96,101],"pre",{"className":97,"code":98,"language":99,"meta":100,"style":100},"language-JavaScript shiki shiki-themes github-dark","import { ref, computed } from 'vue'\n\nconst count = ref(1)\n\u002F\u002F count가 변할 때만 다시 계산됨\nconst doubleCount = computed(() => count.value * 2)\n\nconsole.log(doubleCount.value) \u002F\u002F 2\n","JavaScript","",[18,102,103,123,130,156,163,193,198],{"__ignoreMap":100},[104,105,108,112,116,119],"span",{"class":106,"line":107},"line",1,[104,109,111],{"class":110},"snl16","import",[104,113,115],{"class":114},"s95oV"," { ref, computed } ",[104,117,118],{"class":110},"from",[104,120,122],{"class":121},"sU2Wk"," 'vue'\n",[104,124,126],{"class":106,"line":125},2,[104,127,129],{"emptyLinePlaceholder":128},true,"\n",[104,131,133,136,140,143,147,150,153],{"class":106,"line":132},3,[104,134,135],{"class":110},"const",[104,137,139],{"class":138},"sDLfK"," count",[104,141,142],{"class":110}," =",[104,144,146],{"class":145},"svObZ"," ref",[104,148,149],{"class":114},"(",[104,151,152],{"class":138},"1",[104,154,155],{"class":114},")\n",[104,157,159],{"class":106,"line":158},4,[104,160,162],{"class":161},"sAwPA","\u002F\u002F count가 변할 때만 다시 계산됨\n",[104,164,166,168,171,173,176,179,182,185,188,191],{"class":106,"line":165},5,[104,167,135],{"class":110},[104,169,170],{"class":138}," doubleCount",[104,172,142],{"class":110},[104,174,175],{"class":145}," computed",[104,177,178],{"class":114},"(() ",[104,180,181],{"class":110},"=>",[104,183,184],{"class":114}," count.value ",[104,186,187],{"class":110},"*",[104,189,190],{"class":138}," 2",[104,192,155],{"class":114},[104,194,196],{"class":106,"line":195},6,[104,197,129],{"emptyLinePlaceholder":128},[104,199,201,204,207,210],{"class":106,"line":200},7,[104,202,203],{"class":114},"console.",[104,205,206],{"class":145},"log",[104,208,209],{"class":114},"(doubleCount.value) ",[104,211,212],{"class":161},"\u002F\u002F 2\n",[15,214,215,217],{},[44,216],{},[44,218],{},[10,220,222],{"id":221},"watch-감시자","watch: 감시자",[15,224,225,227],{},[18,226,39],{},"는 특정 데이터가 변경될 때마다 실행되는 콜백 함수를 정의한다.",[15,229,230,232,233,235,236,239],{},[18,231,36],{},"가 값을 '생성' 하는 데 집중한다면, ",[18,234,39],{},"는 값의 변화에 따른 ",[27,237,238],{},"'동작(사이드 이펙트)'"," 을 수행하는 데 집중한다.",[15,241,242],{},[27,243,71],{},[73,245,246,252,261],{},[76,247,248,251],{},[27,249,250],{},"사이드 이펙트 처리:"," API 호출, DOM 직접 조작 등 값을 반환하지 않는 동작에 적합하다.",[76,253,254,257,258,260],{},[27,255,256],{},"비동기 처리:"," ",[18,259,36],{},"와 달리 비동기 처리가 용이하다.",[76,262,263,266],{},[27,264,265],{},"이전 값 확인:"," 변경 전의 값과 변경된 값을 동시에 인자로 받아 비교할 수 있다.",[95,268,270],{"className":97,"code":269,"language":99,"meta":100,"style":100},"import { ref, watch } from 'vue'\n\nconst question = ref('')\n\n\u002F\u002F question 값이 변할 때마다 실행\nwatch(question, (newValue, oldValue) => {\n  console.log(`질문이 '${oldValue}'에서 '${newValue}'로 변경됨`)\n})\n",[18,271,272,283,287,305,309,314,339,363],{"__ignoreMap":100},[104,273,274,276,279,281],{"class":106,"line":107},[104,275,111],{"class":110},[104,277,278],{"class":114}," { ref, watch } ",[104,280,118],{"class":110},[104,282,122],{"class":121},[104,284,285],{"class":106,"line":125},[104,286,129],{"emptyLinePlaceholder":128},[104,288,289,291,294,296,298,300,303],{"class":106,"line":132},[104,290,135],{"class":110},[104,292,293],{"class":138}," question",[104,295,142],{"class":110},[104,297,146],{"class":145},[104,299,149],{"class":114},[104,301,302],{"class":121},"''",[104,304,155],{"class":114},[104,306,307],{"class":106,"line":158},[104,308,129],{"emptyLinePlaceholder":128},[104,310,311],{"class":106,"line":165},[104,312,313],{"class":161},"\u002F\u002F question 값이 변할 때마다 실행\n",[104,315,316,318,321,325,328,331,334,336],{"class":106,"line":195},[104,317,39],{"class":145},[104,319,320],{"class":114},"(question, (",[104,322,324],{"class":323},"s9osk","newValue",[104,326,327],{"class":114},", ",[104,329,330],{"class":323},"oldValue",[104,332,333],{"class":114},") ",[104,335,181],{"class":110},[104,337,338],{"class":114}," {\n",[104,340,341,344,346,348,351,353,356,358,361],{"class":106,"line":200},[104,342,343],{"class":114},"  console.",[104,345,206],{"class":145},[104,347,149],{"class":114},[104,349,350],{"class":121},"`질문이 '${",[104,352,330],{"class":114},[104,354,355],{"class":121},"}'에서 '${",[104,357,324],{"class":114},[104,359,360],{"class":121},"}'로 변경됨`",[104,362,155],{"class":114},[104,364,366],{"class":106,"line":365},8,[104,367,368],{"class":114},"})\n",[15,370,371,373],{},[44,372],{},[44,374],{},[10,376,378],{"id":377},"computed-vs-watch-무엇을-쓸-것인가","computed vs watch: 무엇을 쓸 것인가?",[380,381,382,397],"table",{},[383,384,385],"thead",{},[386,387,388,393,395],"tr",{},[389,390,392],"th",{"align":391},"left","구분",[389,394,36],{"align":391},[389,396,39],{"align":391},[398,399,400,414,427,440],"tbody",{},[386,401,402,408,411],{},[403,404,405],"td",{"align":391},[27,406,407],{},"목적",[403,409,410],{"align":391},"파생된 상태 계산 (데이터 가공)",[403,412,413],{"align":391},"사이드 이펙트 실행 (데이터 감시)",[386,415,416,421,424],{},[403,417,418],{"align":391},[27,419,420],{},"결과값",[403,422,423],{"align":391},"항상 값을 반환해야 함",[403,425,426],{"align":391},"값을 반환할 필요 없음",[386,428,429,434,437],{},[403,430,431],{"align":391},[27,432,433],{},"실행 시점",[403,435,436],{"align":391},"의존성 변경 시 (Lazy)",[403,438,439],{"align":391},"데이터 변경 즉시",[386,441,442,447,450],{},[403,443,444],{"align":391},[27,445,446],{},"성능",[403,448,449],{"align":391},"캐싱 지원 (효율적)",[403,451,452],{"align":391},"로직 수행마다 실행",[44,454],{},[15,456,457],{},[27,458,459],{},"💡 선택 방법:",[461,462,463,470],"ol",{},[76,464,465,466],{},"데이터로부터 다른 값을 만들어야 한다면? → ",[27,467,468],{},[18,469,36],{},[76,471,472,473],{},"데이터 변화를 감지해 외부 API를 호출하거나 무언가를 변경해야 한다면? → ",[27,474,475],{},[18,476,39],{},[15,478,479,481],{},[44,480],{},[44,482],{},[10,484,486],{"id":485},"비유로-이해하기-주문서-와-알림-서비스","비유로 이해하기: '주문서' 와 '알림 서비스'",[73,488,489,499],{},[76,490,491,494,495,498],{},[27,492,493],{},"computed (주문서의 합계):"," 식당 영수증의 '합계' 금액과 같다. 주문한 메뉴(데이터)가 바뀌지 않으면 합계 금액은 다시 계산할 필요가 없다. 메뉴가 추가될 때만 자동으로 계산된 값을 보여주는 ",[27,496,497],{},"자동 계산기"," 이다.",[76,500,501,504,505,498],{},[27,502,503],{},"watch (결제 알림 서비스):"," 카드 결제가 승인(데이터 변경)되면 즉시 사용자에게 '결제 완료' 문자(사이드 이펙트)를 보낸다. 문자 발송은 영수증의 합계 금액 자체와는 상관없는, 데이터 변화 후 수행해야 할 ",[27,506,507],{},"별도의 행동",[15,509,510,512],{},[44,511],{},[44,513],{},[10,515,516],{"id":516},"정리",[73,518,519,524,529],{},[76,520,521,523],{},[27,522,36],{},"는 기존 데이터를 가공하여 새로운 값을 만들며, 의존성이 변하지 않으면 이전 값을 재사용하는 방식으로 동작한다.",[76,525,526,528],{},[27,527,39],{},"는 특정 데이터의 변화를 지켜보다가 그에 따른 외부 동작(API 호출, DOM 조작 등)을 수행한다.",[76,530,531,532,534,535,537],{},"가급적이면 재사용성과 성능이 뛰어난 ",[18,533,36],{},"를 우선적으로 사용하고, 비동기 처리가 필요하거나 데이터 변경 후 특정 동작이 발생해야 할 때 ",[18,536,39],{},"를 사용한다.",[539,540,541],"style",{},"html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s9osk, html code.shiki .s9osk{--shiki-default:#FFAB70}",{"title":100,"searchDepth":125,"depth":125,"links":543},[544,545,546,547,548,549],{"id":12,"depth":125,"text":13},{"id":50,"depth":125,"text":51},{"id":221,"depth":125,"text":222},{"id":377,"depth":125,"text":378},{"id":485,"depth":125,"text":486},{"id":516,"depth":125,"text":516},"2026-04-25","md",{},"\u002Fposts\u002Fvue03",{"title":5,"description":100},"posts\u002Fvue03","데이터의 변화에 따라 파생 값을 생성하는 computed와 사이드 이펙트를 처리하는 watch의 활용법 정리",[558],"Vue","KQd-8s-iO_KVKWzruD3p1dpKTcAFu63n-LLlWTZTzJA",1778993725562]